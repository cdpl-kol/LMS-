# PostgreSQL Database URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:1234@localhost:5432/lms_db

# JWT Secret Key (change this to something secret)
JWT_SECRET=connecting-dot-lms-secret-2024

# ── LMS → Connectingdot Integration ─────────────────────────────────────────
# Connectingdot backend ka webhook URL (production me apna URL daalo)
CONNECTINGDOT_WEBHOOK_URL=http://localhost:8000/api/lms/webhook
# Shared secret — dono jagah same hona chahiye
LMS_WEBHOOK_SECRET=cdpl-lms-secret-2024

# Server Port
PORT=3001

# ── Razorpay Payment Gateway ──────────────────────────────────────────────────
# Live keys — Razorpay dashboard > Settings > API Keys
RAZORPAY_KEY_ID=rzp_live_SmOUbcbz67IF2w
RAZORPAY_KEY_SECRET=ghEU5LyqaiIpWVAHN9P1Kws9

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Gmail account jisse participant ko email bhejega
# Gmail > Account > Security > App Passwords se App Password banao
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-app-password-here

# ── App Base URL ──────────────────────────────────────────────────────────────
